# Trino connection settings
# Copy to ~/.trino.env or ./.trino.env and fill in your values:
#   cp templates/trino.env ~/.trino.env

TRINO_HOST=trino.your-company.com
TRINO_PORT=8080
TRINO_USER=your_username
TRINO_PASSWORD=
TRINO_HTTPS=false
TRINO_VERIFY_SSL=false
TRINO_CATALOG=hive
TRINO_SCHEMA=default
